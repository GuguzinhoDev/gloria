# UTILS
# ══════════════════════════════════════════════════════════════════════════════

def n(txt: str) -> str:
    """Normaliza: minúsculo + sem acento."""
    if not isinstance(txt, str): return ""
    t = unicodedata.normalize("NFD", txt.lower().strip())
    return "".join(c for c in t if unicodedata.category(c) != "Mn")

def tokens(txt: str) -> List[str]:
    return list(set(re.findall(r"[a-z]{3,}", n(txt))))

def html(txt: str) -> str:
    return re.sub(r"<[^>]+>", " ", txt or "")

def xtipo(tipo: str) -> List[str]:
    t = n(tipo)
    for k, vs in TIPOS.items():
        if t in [n(v) for v in vs] or t == n(k): return [n(v) for v in vs]
    return [t]

def xcor(cor: str) -> List[str]:
    c = n(cor)
    for k, vs in CORES.items():
        if c in [n(v) for v in vs] or c == n(k): return [n(v) for v in vs]
    return [c]


