def _preco(txt: str) -> float:
    try:    return float(re.sub(r"[^\d,]", "", txt or "0").replace(",", "."))
    except: return 0.0

def prep(p: Dict) -> Dict:
    nome  = p.get("name", "")
    desc  = html(p.get("description", ""))
    texto = f"{nome} {desc} {p.get('categoryid1','')} {p.get('categoryid2','')}"
    p["_tok"]    = tokens(texto)
    p["_txt"]    = n(texto)
    p["_tipo"]   = n(p.get("categoryid2") or p.get("categoryid1") or "")
    p["_embed"]  = f"{nome}. {p.get('categoryid2','')}. {desc[:300]}"
    p_o = _preco(p.get("price_original","0")); p_a = _preco(p.get("price","0"))
    p["_desc"]   = p_a > 0 and p_a < p_o * 0.95
    p["_stock"]  = n(p.get("instock","")) in ["disponivel","disponível","em estoque","true","1"]
    return p

