# PIPELINE CENTRAL
# ══════════════════════════════════════════════════════════════════════════════

async def _run(texto: Optional[str], img: Optional[bytes], sid: Optional[str]) -> dict:
    estoque = carregar_estoque()
    ctx_novo = await interpretar(texto, img)
    ctx      = await mesclar_ctx(sid or "", ctx_novo)
    prods_raw = await buscar(estoque, ctx)
    prods     = await enriquecer(prods_raw)
    await log("busca", {"texto": texto, "tipo": ctx.get("tipo_produto"),
                         "n": len(prods), "motor": "vetorial" if (CHROMA and _col) else "heuristico"}, sid or "")
    return {
        "status":        "sucesso" if prods else "sem_resultados",
        "interpretacao": ctx,
        "produtos":      prods,
        "proxima_acao":  "sugerir_complementos" if ctx.get("nivel_decisao")=="decidida" else "ajudar_decidir",
    }


