# MEMÓRIA DE SESSÃO
# ══════════════════════════════════════════════════════════════════════════════

_sessoes: Dict[str, Dict] = {}   # fallback em memória quando Redis indisponível
_redis   = None

async def get_redis():
    global _redis
    if _redis: return _redis
    if not REDIS: return None
    try:
        _redis = await aioredis.from_url(REDIS_URL, decode_responses=True)
        await _redis.ping(); print("✅ Redis conectado"); return _redis
    except Exception as e:
        print(f"⚠️  Redis: {e}"); _redis = None; return None

async def mesclar_ctx(sid: str, novo: Dict) -> Dict:
    """Mescla novo contexto com histórico da sessão (Redis ou memória local)."""
    hist: Dict = {}
    redis = await get_redis()
    if redis and sid:
        try:
            raw = await redis.get(f"gloria:s:{sid}")
            hist = json.loads(raw) if raw else {}
        except Exception: pass
    elif sid and sid in _sessoes:
        hist = _sessoes[sid]

    merged = {
        "ocasiao":        novo.get("ocasiao")        or hist.get("ocasiao","geral"),
        "tipo_produto":   novo.get("tipo_produto")   or hist.get("tipo_produto"),
        "cores":          list(set((novo.get("cores") or []) + (hist.get("cores") or []))),
        "palavras_chave": list(set((novo.get("palavras_chave") or []) + (hist.get("palavras_chave") or []))),
        "estilo_cliente": novo.get("estilo_cliente") or hist.get("estilo_cliente","casual"),
        "nivel_decisao":  novo.get("nivel_decisao","explorando"),
        "intencao":       novo.get("intencao","comprar"),
        "evitar":         list(set((novo.get("evitar") or []) + (hist.get("evitar") or []))),
        "sugestao_extra": novo.get("sugestao_extra") or hist.get("sugestao_extra") or [],
        "tamanho_cliente":novo.get("tamanho_cliente") or hist.get("tamanho_cliente"),
    }

    if redis and sid:
        try: await redis.setex(f"gloria:s:{sid}", SESSION_TTL, json.dumps(merged, ensure_ascii=False))
        except Exception: pass
    elif sid:
        _sessoes[sid] = merged

    return merged


