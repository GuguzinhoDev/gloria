# RE-RANKING GEMINI
# ══════════════════════════════════════════════════════════════════════════════

async def rerank(cands: List[Dict], ctx: Dict) -> List[Dict]:
    if len(cands) <= 3: return cands[:6]
    resumo = [{"idx": i, "nome": p.get("name",""),
                "cat": f"{p.get('categoryid1','')} / {p.get('categoryid2','')}",
                "desc": html(p.get("description",""))[:180],
                "preco": p.get("price",""), "desc_flag": p.get("_desc",False)}
               for i, p in enumerate(cands)]
    prompt = (f"Motor de busca moda. Contexto: ocasião={ctx.get('ocasiao')} "
              f"tipo={ctx.get('tipo_produto')} cores={ctx.get('cores')} "
              f"estilo={ctx.get('estilo_cliente')} keywords={ctx.get('palavras_chave')} "
              f"evitar={ctx.get('evitar')} tamanho={ctx.get('tamanho_cliente')}\n"
              f"Candidatos: {json.dumps(resumo, ensure_ascii=False)}\n"
              f"Ranqueie os 6 melhores (relevância + diversidade, sem repetir modelo+cor).\n"
              f"Responda SOMENTE: {{\"ranking\":[idx,idx,idx,idx,idx,idx]}}")
    try:
        resp    = gemini.models.generate_content(model=GEMINI_MODEL, contents=prompt,
                    config=GenerateContentConfig(response_mime_type="application/json"))
        indices = json.loads(resp.text).get("ranking",[])[:6]
        result  = [cands[i] for i in indices if 0 <= i < len(cands)]
        usados  = set(indices)
        for i, p in enumerate(cands):
            if len(result) >= 6: break
            if i not in usados: result.append(p)
        return result
    except Exception as e:
        print(f"⚠️  Re-rank: {e}"); return cands[:6]


