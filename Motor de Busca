# ══════════════════════════════════════════════════════════════════════════════

async def interpretar(texto: Optional[str], img: Optional[bytes]) -> Dict:
    prompt = """Você é a GlorIA, personal stylist de calçados e bolsas.
Retorne JSON ESTRITO:
{"ocasiao":string,"tipo_produto":string|null,"cores":list,"palavras_chave":list,
 "estilo_cliente":string,"nivel_decisao":"decidida"|"indecisa"|"explorando",
 "intencao":"comprar"|"inspiracao"|"comparar","evitar":list,"sugestao_extra":list,
 "tamanho_cliente":string|null}
Regras: tipo_produto=nome exato PT (mule|scarpin|sandália|sapatilha|tênis|bota|bolsa|mocassim)
ocasiao=trabalho|casual|festa|praia|esporte|passeio|geral
cores=inclua implícitas("terra"→"caramelo"), keywords=max 6 termos, estilo=UMA palavra
sugestao_extra=categorias CURTAS complementares, tamanho_cliente=só se mencionado"""
    conteudo = [prompt]
    if texto: conteudo.append(f"Mensagem: {texto}")
    if img:
        try: conteudo.append(Image.open(io.BytesIO(img)))
        except: pass
    try:
        r = gemini.models.generate_content(model=GEMINI_MODEL, contents=conteudo,
                config=GenerateContentConfig(response_mime_type="application/json"))
        return json.loads(r.text)
    except Exception as e:
        print(f"⚠️  Intenção: {e}")
        return {"ocasiao":"geral","tipo_produto":None,"cores":[],"palavras_chave":["estilo"],
                "estilo_cliente":"casual","nivel_decisao":"explorando","intencao":"comprar",
                "evitar":[],"sugestao_extra":[],"tamanho_cliente":None}


