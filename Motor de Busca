async def tamanhos(id_produto: str):
    """Tamanhos disponíveis em tempo real."""
    ev = await estoque_vtex(id_produto)
    if ev:
        try: return {"id": id_produto, "tamanhos": sorted(ev, key=lambda x: int(re.sub(r"\D","",x))), "fonte":"vtex_api"}
