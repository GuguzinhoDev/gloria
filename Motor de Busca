async def sku_ativo(id_sku: str) -> bool:
    try:
        async with httpx.AsyncClient(timeout=6.0) as h:
            r = await h.get(f"{VTEX_BASE}/api/catalog_system/pub/sku/stockkeepingunitbyid/{id_sku}",
                            headers={"Accept":"application/json"})
            return r.json().get("IsActive", False)
