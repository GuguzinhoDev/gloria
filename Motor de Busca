# HANDLER 422 (file inválido do Swagger/Lovable)
# ══════════════════════════════════════════════════════════════════════════════

@app.exception_handler(RequestValidationError)
async def val_handler(request: Request, exc: RequestValidationError):
    if all("file" in (e.get("loc") or []) for e in exc.errors()):
        try:
            form = await request.form()
            return JSONResponse(content=await _run(form.get("texto"), None, form.get("session_id")))
        except Exception as e:
            print(f"❌ Fallback: {e}")
    return JSONResponse(status_code=422, content={"detail": exc.errors()})


