# CROSS-SELL
# ══════════════════════════════════════════════════════════════════════════════

def cross_sell(estoque: List[Dict], principais: List[Dict], ctx: Dict) -> List[Dict]:
    tipos_ja = {p.get("_tipo","") for p in principais}
    ids_ja   = {str(p.get("idProduto","")) for p in principais}
    tok_sug  = [t for s in ctx.get("sugestao_extra",[]) for t in tokens(s)[:5]]
    cands    = []
    for p in estoque:
        if str(p.get("idProduto","")) in ids_ja or p.get("_tipo","") in tipos_ja: continue
        sc = sum(3 for t in tok_sug if len(t)>3 and t in p.get("_txt",""))
        if sc >= 3:
            c = p.copy(); c["_score"] = sc; c["_cross"] = True; cands.append(c)
    cands.sort(key=lambda x: -x["_score"]); return cands[:2]


# ══════════════════════════════════════════════════════════════════════════════
# MOTOR PRINCIPAL
# ══════════════════════════════════════════════════════════════════════════════

async def buscar(estoque: List[Dict], ctx: Dict) -> List[Dict]:
    """
    Pipeline completo:
      1. Monta query enriquecida
      2. Busca vetorial (ChromaDB) se disponível
      3. Busca BM25 em paralelo
      4. Fusão RRF
      5. Fallback heurístico 7 camadas se vetorial não disponível
      6. Hard filter (termos a evitar)
      7. Re-rank Gemini (top-12 → top-6)
      8. Cross-sell para completar
    """
    tip_alvo  = n(ctx.get("tipo_produto") or "")
    evitar    = [n(e) for e in ctx.get("evitar",[]) if len(e) > 3]
    mapa      = {str(p.get("idProduto","")): p for p in estoque}

    # Query enriquecida
    q = " ".join(filter(None, [
        ctx.get("tipo_produto",""),
        " ".join(ctx.get("cores",[])),
        " ".join(ctx.get("palavras_chave",[])[:4]),
        ctx.get("ocasiao",""),
    ]))

    ranking: List[Tuple[str, float]] = []

    col = get_col()
    if CHROMA and col and col.count() > 0:
        vet = await busca_vetorial(q, 25)
        bm  = busca_bm25(q, 25)
        rnks = [r for r in [vet, bm] if r]
        if rnks: ranking = rrf(rnks)

    # Fallback heurístico
    if not ranking:
        heur = []
        for p in estoque:
            if any(ev in p.get("_txt","") for ev in evitar): continue
            sc = score(p, ctx)
            if sc >= (25 if tip_alvo else 15): heur.append((str(p.get("idProduto","")), float(sc)))
        heur.sort(key=lambda x: -x[1]); ranking = heur

    # Monta candidatos com hard filter
    cands = []
    for doc_id, sc in ranking[:12]:
        p = mapa.get(doc_id)
        if not p or any(ev in p.get("_txt","") for ev in evitar): continue
        c = p.copy(); c["_score"] = round(sc, 4); cands.append(c)

    top = await rerank(cands, ctx) if cands else []

    if len(top) < 6:
        top += cross_sell(estoque, top, ctx)

    # Remove campos internos
    return [{k: v for k, v in p.items() if not k.startswith("_") or k == "_score"}
            for p in top[:6]]


