@app.post("/carrinho/adicionar", response_model=AddCarrinhoResponse)
async def adicionar_carrinho(req: AddCarrinhoRequest, request: Request):
    """
    Adiciona SKU ao carrinho VTEX.
    Passe o cookie vtex_session no campo session_id.
    Redirecione o cliente para checkout_url após sucesso.
    """
    session = req.session_id or request.cookies.get("vtex_session")
    try:
        if not await sku_ativo(req.id_sku):
            return AddCarrinhoResponse(sucesso=False, mensagem="Produto indisponível.")

        ofid = await get_order_form(session)
        if not ofid:
            return AddCarrinhoResponse(sucesso=False, mensagem="Sessão não encontrada. Tente pelo link do produto.")

        if not await add_item(ofid, req.id_sku, req.quantidade, session):
            return AddCarrinhoResponse(sucesso=False, mensagem="Erro ao adicionar. Tente pelo link do produto.")

        await log("add_cart", {"sku": req.id_sku, "qty": req.quantidade})
        return AddCarrinhoResponse(
            sucesso=True,
            checkout_url=f"{VTEX_BASE}/checkout#/cart",
            order_form_id=ofid,
            mensagem="Adicionado ao carrinho! Clique para finalizar 🛒",
        )
    except Exception as e:
        print(f"❌ /carrinho/adicionar: {e}")
        return AddCarrinhoResponse(sucesso=False, mensagem="Erro interno. Tente pelo link!")


