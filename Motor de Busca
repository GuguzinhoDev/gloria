_vtex: Dict[str, Dict[str, int]] = {}

async def estoque_vtex(id_p: str) -> Dict[str, int]:
    if id_p in _vtex: return _vtex[id_p]
    url = f"{VTEX_BASE}/api/catalog_system/pub/products/search?fq=productId:{id_p}&_from=0&_to=0"
    try:
        async with httpx.AsyncClient(timeout=8.0) as h:
            r = await h.get(url, headers={"Accept":"application/json","User-Agent":"GlorIA/2.0"})
            r.raise_for_status(); dados = r.json()
    except Exception as e:
        print(f"⚠️  VTEX estoque {id_p}: {e}"); _vtex[id_p] = {}; return {}

    est: Dict[str, int] = {}
    try:
        for item in (dados[0].get("items",[]) if dados else []):
            tam = None
            for spec in item.get("variations",[]):
                if any(x in spec.get("name","").lower() for x in ["tamanho","tam","size","numero"]):
                    vals = spec.get("values",[]); tam = str(vals[0]) if vals else None; break
            if not tam:
                m = re.search(r"\b([3-4][0-9])\b", item.get("name","")); tam = m.group(1) if m else None
            if not tam: continue
            qtd = sum(s.get("commertialOffer",{}).get("AvailableQuantity",0) for s in item.get("sellers",[]))
            if qtd > 1: est[tam] = qtd
    except Exception as e:
        print(f"⚠️  Parse VTEX {id_p}: {e}")
    _vtex[id_p] = est; return est

def tams_desc(desc: str) -> List[str]:
    txt = html(desc)
    m   = re.search(r"(?:do\s+(?:tamanho\s+)?|de\s+(?:tamanho\s+)?)(\d{2})(?:\s+(?:ao?|até|a)\s+(?:o\s+)?)(\d{2})", txt, re.I)
    if m:
        a, b = int(m.group(1)), int(m.group(2))
        if 30 <= a <= 49 and a <= b: return [str(i) for i in range(a, b+1)]
    nums = re.findall(r"\b([3-4][0-9])\b", txt)
    return sorted(dict.fromkeys(nums), key=int) if nums else []

async def enriquecer(prods: List[Dict]) -> List[Dict]:
    for p in prods:
        try:
            id_p = str(p.get("idProduto",""))
            tams: List[str] = []; fonte = "vtex_api"
            if id_p:
                ev = await estoque_vtex(id_p)
                if ev:
                    try: tams = sorted(ev.keys(), key=lambda x: int(re.sub(r"\D","",x)))
                    except: tams = sorted(ev.keys())
            if not tams:
                tams = tams_desc(p.get("description","")); fonte = "descricao_estimado"
            p["tamanhos_disponiveis"] = tams; p["tamanhos_fonte"] = fonte
        except Exception as e:
            print(f"⚠️  Tam {p.get('idProduto')}: {e}")
            p.setdefault("tamanhos_disponiveis",[]); p.setdefault("tamanhos_fonte","erro")
    return prods


