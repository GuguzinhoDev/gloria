_col = None

def get_col():
    global _col
    if _col: return _col
    if not CHROMA: return None
    try:
        db   = chromadb.PersistentClient(path=CHROMA_PATH)
        _col = db.get_or_create_collection("gloria", metadata={"hnsw:space": "cosine"})
        return _col
    except Exception as e:
        print(f"⚠️  ChromaDB: {e}"); return None

async def indexar(estoque: List[Dict]) -> int:
    col = get_col()
    if not col: return 0
    existentes  = set(col.get(include=[])["ids"])
    faltando    = [p for p in estoque if str(p.get("idProduto","")) not in existentes]
    if not faltando:
        print(f"✅ Vetorial: {len(existentes)} já indexados"); return len(existentes)
    total = 0
    for i in range(0, len(faltando), 100):
        lote   = faltando[i:i+100]
        textos = [p["_embed"] for p in lote]
        ids    = [str(p["idProduto"]) for p in lote]
        metas  = [{"tipo": p["_tipo"], "disponivel": str(p["_stock"])} for p in lote]
        try:
            resp = gemini.models.embed_content(model=EMBED_MODEL, content=textos)
            col.add(ids=ids, embeddings=[e.values for e in resp.embeddings],
                    documents=textos, metadatas=metas)
            total += len(lote)
        except Exception as e:
            print(f"⚠️  Embed lote {i}: {e}")
    print(f"✅ Vetorial: {total} indexados"); return total

async def busca_vetorial(query: str, k: int = 25) -> List[Tuple[str, float]]:
    col = get_col()
    if not col or col.count() == 0: return []
    try:
        emb     = gemini.models.embed_content(model=EMBED_MODEL, content=query).embeddings[0].values
        res     = col.query(query_embeddings=[emb], n_results=min(k, col.count()), include=["distances"])
        return list(zip(res["ids"][0], [1.0 - d/2.0 for d in res["distances"][0]]))
    except Exception as e:
        print(f"⚠️  Vetorial: {e}"); return []


# ══════════════════════════════════════════════════════════════════════════════
# RECIPROCAL RANK FUSION
# ══════════════════════════════════════════════════════════════════════════════

def rrf(rankings: List[List[Tuple[str, float]]], k: int = 60) -> List[Tuple[str, float]]:
    sc: Dict[str, float] = defaultdict(float)
    for ranking in rankings:
        for pos, (doc_id, _) in enumerate(ranking):
            sc[doc_id] += 1.0 / (k + pos + 1)
    return sorted(sc.items(), key=lambda x: -x[1])


# ══════════════════════════════════════════════════════════════════════════════
# SCORING HEURÍSTICO (7 CAMADAS — fallback)
# ══════════════════════════════════════════════════════════════════════════════

def score(p: Dict, ctx: Dict) -> int:
    sc = 0
    tok = set(p["_tok"]); txt = p["_txt"]
    oc  = n(ctx.get("ocasiao","geral"))
    tip = n(ctx.get("tipo_produto") or "")

    # 1. Tipo + sinônimos (max 60)
    if tip:
        for s in xipo(tip):
            if s in txt: sc += 60 if s == tip else 45; break

    # 2. Ocasião (max 40)
    c = OCASIOES.get(oc, OCASIOES["geral"])
    if any(n(t) in txt for t in c["tipos"]): sc += 25
    sc += min(sum(1 for e in c["estilos"] if n(e) in txt) * 5, 15)
    if any(n(e) in txt for e in c["evitar"] if len(e) > 3): sc -= 30

    # 3. Cor + paleta (max 35)
    pc = 0
    for cor in ctx.get("cores",[]):
        for tom in xcor(cor):
            if tom in txt: pc += 35; break
    sc += min(pc, 35)

    # 4. Keywords (max 50)
    pk = 0
    for kw in [n(k) for k in ctx.get("palavras_chave",[])]:
        if kw in tok: pk += 20
        elif len(kw) > 4 and kw in txt: pk += 10
        else:
            for grp, pals in ESTILOS.items():
                if kw in [n(p) for p in pals] and any(n(p) in tok for p in pals):
                    pk += 8; break
    sc += min(pk, 50)

    # 5. Estilo (max 20)
    est = n(ctx.get("estilo_cliente",""))
    for grp, pals in ESTILOS.items():
        if est in [n(p) for p in pals]:
            if any(n(p) in tok for p in pals): sc += 20
            break

    # 6. Material (max 15)
    kws = [n(k) for k in ctx.get("palavras_chave",[])]
    for grp, pals in MATERIAIS.items():
        if any(n(p) in kws for p in pals) and any(n(p) in tok for p in pals):
            sc += 15; break

    # 7. Boosts (max 25)
    if p.get("_stock"): sc += 10
    if p.get("_desc"):  sc += 15

    return sc

# Corrige nome da função que estava errado acima
def xipo(tipo: str) -> List[str]:
    return xtype(tipo)

def xtype(tipo: str) -> List[str]:
    t = n(tipo)
    for k, vs in TIPOS.items():
        if t in [n(v) for v in vs] or t == n(k): return [n(v) for v in vs]
    return [t]


