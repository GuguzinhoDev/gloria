async def add_item(ofid: str, id_sku: str, qty: int, session: Optional[str]) -> bool:
    url     = f"{VTEX_BASE}/api/checkout/pub/orderForm/{ofid}/items"
    payload = {"orderItems": [{"id": id_sku, "quantity": qty, "seller": "1"}]}
    cookies = {"vtex_session": session} if session else {}
    try:
        async with httpx.AsyncClient(timeout=10.0) as h:
            r = await h.post(url, json=payload, cookies=cookies,
                             headers={"Content-Type":"application/json","Accept":"application/json"})
            ok = r.status_code in (200, 201)
            if not ok: print(f"⚠️  Add item {r.status_code}: {r.text[:200]}")
            return ok
    except Exception as e:
        print(f"❌ Add item: {e}"); return False


